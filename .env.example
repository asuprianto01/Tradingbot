# Copy this file to .env and fill in your Crypto.com Exchange API credentials.
# Create keys at: https://crypto.com/exchange -> Settings -> API Keys
# For safety: enable only "Read" + "Trade" permissions, NEVER "Withdraw",
# and restrict the key to your IP address.
CRYPTO_API_KEY=
CRYPTO_API_SECRET=

# (Opsional) Kirim sinyal screener ke Telegram.
# Buat bot lewat @BotFather, salin token-nya ke sini.
TELEGRAM_BOT_TOKEN=

# Daftar penerima Telegram (chat_id), dipisahkan dengan koma.
# Cara mendapat chat_id: kirim /start ke bot, lalu buka
# https://api.telegram.org/bot<TOKEN>/getUpdates
# Contoh: TELEGRAM_CHAT_IDS=123456789,-1001234567890
TELEGRAM_CHAT_IDS=
